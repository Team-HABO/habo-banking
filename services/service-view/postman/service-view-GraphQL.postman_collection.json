        {
            "name": "Get Account Audits",
            "event": [
                {
                    "listen": "test",
                    "script": {
                        "exec": [
                            "const response = pm.response.json();\r",
                            "const audits = response.data.getAccountAudits;\r",
                            "\r",
                            "pm.test(\"Response status code is 200\", () => {\r",
                            "    pm.response.to.have.status(200);\r",
                            "});\r",
                            "\r",
                            "pm.test(\"Audit list is an array and not empty\", () => {\r",
                            "    pm.expect(audits).to.be.an('array');\r",
                            "    pm.expect(audits.length).to.be.at.least(1);\r",
                            "});\r",
                            "\r",
                            "pm.test(\"Every audit has required keys\", () => {\r",
                            "    audits.forEach((audit) => {\r",
                            "        pm.expect(audit).to.have.all.keys(\r",
                            "            'amount', 'auditId', 'receiver', 'sender', 'timestamp', 'type'\r",
                            "        );\r",
                            "    });\r",
                            "});\r",
                            "pm.test(\"Amounts are valid numeric strings\", () => {\r",
                            "    audits.forEach((audit) => {\r",
                            "        const val = parseFloat(audit.amount);\r",
                            "        pm.expect(isNaN(val)).to.be.false;\r",
                            "        pm.expect(val).to.be.above(0);\r",
                            "    });\r",
                            "});"
                        ],
                        "type": "text/javascript",
                        "packages": {},
                        "requests": {}
                    }
                }
            ],
            "request": {
                "method": "POST",
                "header": [
                    {
                        "key": "Content-Type",
                        "value": "application/json"
                    },
                    {
                        "key": "Cookie",
                        "value": "auth_token={{jwt_token}}",
                        "type": "text"
                    }
                ],
