        {
            "name": "Get User Accounts Unauthenticated",
            "event": [
                {
                    "listen": "test",
                    "script": {
                        "exec": [
                            "\r",
                            "pm.test(\"Status code is 200\", function () {\r",
                            "    pm.response.to.have.status(200);\r",
                            "});\r",
                            "\r",
                            "const response = pm.response.json();\r",
                            "pm.test(\"Response has errors\", () => {\r",
                            "    pm.expect(response.errors).to.be.an('array');\r",
                            "});\r",
                            "pm.test(\"Error message is 'Unauthorized'\", () => {\r",
                            "    pm.expect(response.errors[0].message).to.equal('Unauthorized');\r",
