        {
            "name": "Get User Accounts",
            "event": [
                {
                    "listen": "test",
                    "script": {
                        "exec": [
                            "pm.test(\"Status code is 200\", function () {\r",
                            "    pm.response.to.have.status(200);\r",
                            "});\r",
                            "const response = pm.response.json();\r",
                            "pm.test(\"Response has user accounts\", () => {\r",
                            "    pm.expect(response.data.getUserAccounts).to.be.an('array');\r",
                            "    pm.expect(response.data.getUserAccounts.length).to.be.above(0);\r",
                            "});\r",
                            "\r",
                            "pm.test(\"Account object has correct fields\", () => {\r",
                            "    const account = response.data.getUserAccounts[0];\r",
                            "    pm.expect(account).to.have.all.keys('accountGuid', 'balance', 'name', 'type');\r",
                            "    pm.expect(account.accountGuid).to.be.a('string');\r",
                            "});\r",
                            "pm.test(\"Balance is a valid positive number\", () => {\r",
                            "    const balanceStr = response.data.getUserAccounts[0].balance;\r",
                            "    const balanceNum = parseFloat(balanceStr);\r",
                            "    \r",
                            "    pm.expect(isNaN(balanceNum)).to.be.false;\r",
                            "    pm.expect(balanceNum).to.be.at.least(0);\r",
                            "});\r",
                            "\r",
                            "const accountGuid = response.data.getUserAccounts[0].accountGuid;\r",
                            "\r",
                            "pm.collectionVariables.set(\"accountGuid\", accountGuid);\r",
                            ""
                        ],
                        "type": "text/javascript",
                        "packages": {},
                        "requests": {}
                    }
                }
            ],
            "request": {
                "method": "POST",
                "header": [
                    {
                        "key": "Content-Type",
                        "value": "application/json"
                    },
                    {
                        "key": "Cookie",
                        "value": "auth_token={{jwt_token}}",
                        "type": "text"
                    }
                ],
                "body": {
                    "mode": "graphql",
                    "graphql": {
                        "query": "query GetUserAccounts {\r\n  getUserAccounts {\r\n    accountGuid\r\n    balance\r\n    name\r\n    type\r\n  }\r\n}",
                        "variables": ""
                    }
                },
